APP_NAME=BuilderOS
APP_ENV=development
DATABASE_URL=postgresql+psycopg://builderos:change-me@postgres:5432/builderos
POSTGRES_DB=builderos
POSTGRES_USER=builderos
POSTGRES_PASSWORD=change-me
API_PORT=8000
FRONTEND_PORT=3000

JWT_SECRET=change-me-to-a-long-random-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

FIRST_USER_EMAIL=admin@example.com
FIRST_USER_PASSWORD=change-me
FIRST_USER_NAME=Администратор

REDIS_URL=redis://redis:6379/0
QDRANT_HOST=qdrant
QDRANT_PORT=6333
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=builderos
MINIO_SECRET_KEY=builderos-secret
MINIO_BUCKET=builderos
MINIO_SECURE=false

# LLM: ollama | omniroute | hybrid (локально, затем OmniRoute)
LLM_ENABLED=true
LLM_PROVIDER=hybrid
LLM_BASE_URL=http://ollama:11434
LLM_MODEL=qwen2.5:7b
LLM_API_KEY=
LLM_AUTO_PULL=true
LLM_TIMEOUT_SECONDS=60
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=1024
OLLAMA_PORT=11434

# OmniRoute — бесплатный gateway (профиль docker: --profile omniroute)
# https://github.com/diegosouzapw/OmniRoute
LLM_FALLBACK_BASE_URL=http://omniroute:20128
LLM_FALLBACK_MODEL=auto/cheap
LLM_FALLBACK_API_KEY=
LLM_CLOUD_FOR_KNOWLEDGE=false
OMNIROUTE_PORT=20128

# RAG / Qdrant
RAG_ENABLED=true
RAG_COLLECTION=builderos_knowledge
RAG_TOP_K=8
RAG_SCORE_THRESHOLD=0.15
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_DIM=768
EMBEDDING_BASE_URL=http://ollama:11434
EMBEDDING_TIMEOUT_SECONDS=60
